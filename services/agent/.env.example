# DecisionBox Agent Configuration
# Warehouse, LLM provider/model, and datasets are configured per-project in MongoDB.

# --- Required ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=decisionbox

# LLM API Key (secret — not stored in database)
# Required for claude/openai providers.
LLM_API_KEY=your-api-key

# --- Optional ---
LOG_LEVEL=info
