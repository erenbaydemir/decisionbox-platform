# DecisionBox Platform Configuration
# Copy to .env and fill in your values

# LLM API Key (secret — not stored in database)
# Required for claude/openai providers. Not needed for ollama/vertex-ai/bedrock.
LLM_API_KEY=your-api-key

# Everything else (warehouse, LLM provider/model, datasets) is configured
# per-project in the dashboard and stored in MongoDB.
